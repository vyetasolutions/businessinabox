# ---- Supabase (Project Settings -> API) ----
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-KEEP-SECRET

# ---- Lenco (mobile money billing) ----
# Get your API key from your Lenco dashboard/account manager.
LENCO_API_KEY=your-lenco-secret-api-key

# ---- Twilio WhatsApp Sandbox (Console -> Messaging -> Try it out -> WhatsApp) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---- Security ----
# Shared secret the frontend/Supabase webhook must send back to prove the
# request is legitimate. Generate any long random string.
BACKEND_SHARED_SECRET=change-this-to-a-long-random-string

# ---- CORS ----
# Comma-separated list of allowed frontend origins (your Render static site URL,
# plus http://localhost:5173 for local dev)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# ---- Server ----
PORT=10000
